{
  "kind": "collectionType",
  "collectionName": "tasks",
  "info": {
    "singularName": "task",
    "pluralName": "tasks",
    "displayName": "Task"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "blocks"
    },
    "project": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::project.project",
      "inversedBy": "tasks"
    },
    "assigned_to": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "tasks"
    },
    "statuts": {
      "type": "enumeration",
      "enum": [
        "TODO",
        "IN_PROGRESS",
        "DONE"
      ]
    },
    "priority": {
      "type": "enumeration",
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH"
      ]
    },
    "due_date": {
      "type": "date"
    }
  }
}
