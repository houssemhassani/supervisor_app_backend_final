{
  "kind": "collectionType",
  "collectionName": "overtime_requests",
  "info": {
    "singularName": "overtime-request",
    "pluralName": "overtime-requests",
    "displayName": "Overtime Request",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "project": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::project.project",
      "inversedBy": "overtime_requests"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "overtime_requests"
    },
    "hours": {
      "type": "integer",
      "required": true,
      "min": 1,
      "max": 24
    },
    "reason": {
      "type": "text",
      "required": true
    },
    "statuts": {
      "type": "enumeration",
      "enum": ["PENDING", "APPROVED", "REJECTED"],
      "default": "PENDING"
    },
    "manager": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "approval_date": {
      "type": "datetime"
    },
    "manager_comments": {
      "type": "text"
    },
    "date": {
      "type": "date",
      "required": true
    }
  }
}